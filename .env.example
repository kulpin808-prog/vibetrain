# Опционально: порт для npm start
PORT=3000

# Neon Postgres (строка «Connection string» из консоли, ветка production / main)
# Для Railway: добавь ту же переменную DATABASE_URL в Variables сервиса
# https://neon.com/docs/guides/railway
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
