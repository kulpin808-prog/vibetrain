# Скопируйте в .env и заполните (файл .env не коммитится)
# Бот @vibetrain — токен из @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ из platform.openai.com
OPENAI_API_KEY=

# Публичный HTTPS URL, где открывается Web App (локально: http://localhost:3000)
# В проде = тот же URL, что выдаёт Railway/Render (без слэша в конце)
TELEGRAM_WEBAPP_URL=http://localhost:3000
WEBAPP_URL=http://localhost:3000

# Опционально: Google Sheets / Notion
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Продакшен (Railway подставляет PORT сам)
NODE_ENV=development
PORT=3000

# Только если настроите webhook вместо polling (необязательно)
# WEBHOOK_URL=https://your-app.up.railway.app
